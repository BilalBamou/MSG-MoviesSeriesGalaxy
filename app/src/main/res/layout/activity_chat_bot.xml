<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_ofBackground"
    tools:context=".ChatBotActivity">

    <LinearLayout
        android:id="@+id/chatBotActivity_toolBarId"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@color/color_ofBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:id="@+id/chatBotActivity_arrowBackId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#00121212"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/arrow_back_icon" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/chatBotActivity_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="7dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="1dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="MSG AI Assistant"
            android:textColor="#F0F3F8"
            android:textSize="19dp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:visibility="gone"
        android:id="@+id/chatBotActivity_recyclerViewId"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/chatBotActivity_toolBarId"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="10dp"
        android:layout_above="@+id/aboutMovieOrSerieActivity_commentEditText_linearLayout"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:id="@+id/aboutMovieOrSerieActivity_commentEditText_linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/aboutMovieOrSerieActivity_commentEditTextId"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="12dp"
            android:layout_weight="7"
            android:paddingBottom="4dp"
            android:textColorHint="#BEBEBE"
            app:boxCornerRadiusBottomEnd="25dp"
            app:boxCornerRadiusBottomStart="25dp"
            app:boxCornerRadiusTopEnd="25dp"
            app:boxCornerRadiusTopStart="25dp"
            app:boxStrokeColor="@color/text_input_layout_stroke_color_selector"
            app:endIconCheckable="true"
            app:endIconMode="clear_text"
            app:endIconTint="#FFFFFF"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Type your message..."
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/aboutMovieOrSerieActivity_sendCommentBtnId"
            android:layout_width="43dp"
            android:layout_height="43dp"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="2dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#00121212"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/aboutMovieOrSerieActivity_sendCommentBtnId_Icon"
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:layout_gravity="center"
                android:layout_marginLeft="1.3dp"
                android:src="@drawable/send_comment_gray_icon" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/chatBotActivity_relativeViewId"
        android:layout_above="@+id/aboutMovieOrSerieActivity_commentEditText_linearLayout"
        android:layout_below="@id/chatBotActivity_toolBarId"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/chatBotActivity_linearLayoutId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="50dp"
            android:layout_marginRight="20dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/chatBotActivity_userName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/aldrich"
                android:gravity="center"
                android:lineSpacingExtra="5dp"
                android:text="Hi Bilal"
                android:textColor="@color/white"
                android:textSize="26dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="This is MSG AI Assistant. Ask me about Cinematic Universe!"
                android:textColor="@color/gray"
                android:textSize="16dp" />
        </LinearLayout>

        <com.airbnb.lottie.LottieAnimationView
            android:layout_below="@id/chatBotActivity_linearLayoutId"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:layout_marginTop="35dp"
            app:lottie_rawRes="@raw/ai_animation" />

    </RelativeLayout>

</RelativeLayout>